<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NestMatch — قرّر بمعلومة</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #0D1F3C;
    --navy-deep: #060E1C;
    --navy-mid: #1E3A5F;
    --gold: #C9A84C;
    --gold-light: #E5C86E;
    --gold-pale: #F2E0A8;
    --warm-white: #F5F3EE;
    --warm-gray: #E8E5DE;
    --divider: #C8C4BA;
    --text-dark: #3D3D3A;
    --text-secondary: #6B7A8D;
    --green: #1D9E75;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--warm-white);
    color: var(--text-dark);
    direction: rtl;
    line-height: 1.7;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    background: rgba(13, 31, 60, 0.96);
    backdrop-filter: blur(8px);
    padding: 0 5%;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(201,168,76,0.15);
  }

  .logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.5px;
  }
  .logo span:first-child { color: var(--gold); }
  .logo span:last-child { color: #fff; }

  .nav-cta {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--navy);
    background: var(--gold);
    border: none;
    padding: 8px 20px;
    border-radius: 4px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s;
  }
  .nav-cta:hover { background: var(--gold-light); }

  /* ── HERO ── */
  #hero {
    background: var(--navy);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100px 5% 80px;
    position: relative;
    overflow: hidden;
  }

  #hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(201,168,76,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(201,168,76,0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 760px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .badge-no-commission {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(201,168,76,0.15);
    border: 1px solid rgba(201,168,76,0.4);
    color: var(--gold);
    font-size: 13px;
    font-weight: 500;
    padding: 6px 18px;
    border-radius: 100px;
    margin-bottom: 36px;
    letter-spacing: 0.3px;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }

  .hero-headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 5.5vw, 60px);
    font-weight: 300;
    color: #fff;
    line-height: 1.25;
    margin-bottom: 20px;
    letter-spacing: -0.3px;
  }

  .hero-headline em {
    color: var(--gold);
    font-style: normal;
  }

  .hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    margin-bottom: 48px;
    max-width: 580px;
    margin-right: auto;
    margin-left: auto;
  }

  .hero-sub strong {
    color: rgba(255,255,255,0.9);
    font-weight: 500;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--gold);
    color: var(--navy-deep);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 500;
    padding: 16px 40px;
    border-radius: 6px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    letter-spacing: 0.2px;
  }

  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
  }

  .btn-arrow {
    font-size: 18px;
    line-height: 1;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    margin-top: 52px;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .trust-item {
    text-align: center;
  }

  .trust-number {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 400;
    color: var(--gold);
    line-height: 1;
  }

  .trust-label {
    display: block;
    font-size: 12px;
    color: rgba(255,255,255,0.45);
    margin-top: 4px;
    letter-spacing: 0.3px;
  }

  .trust-divider {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.1);
  }

  /* ── SECTION BASE ── */
  section {
    padding: 96px 5%;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    display: block;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 300;
    line-height: 1.25;
    letter-spacing: -0.3px;
    color: var(--navy);
    margin-bottom: 16px;
  }

  .section-sub {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 560px;
  }

  /* ── PROBLEM ── */
  #problem {
    background: var(--warm-white);
  }

  .problem-cards {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 48px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--divider);
  }

  .problem-card {
    background: #fff;
    padding: 36px 40px;
    display: flex;
    gap: 32px;
    align-items: flex-start;
  }

  .problem-card-accent {
    background: var(--navy);
  }

  .problem-card-accent .problem-card-title {
    color: #fff;
  }

  .problem-card-accent .problem-card-desc {
    color: rgba(255,255,255,0.55);
  }

  .problem-card-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px;
    font-weight: 300;
    color: var(--divider);
    line-height: 1;
    flex-shrink: 0;
    width: 48px;
  }

  .problem-card-body {
    flex: 1;
  }

  .problem-card-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .problem-card-desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .problem-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .problem-tag {
    background: var(--warm-gray);
    color: var(--text-secondary);
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 100px;
  }

  @media (max-width: 600px) {
    .problem-card { flex-direction: column; gap: 12px; padding: 28px 24px; }
  }

  /* ── HIDDEN KNOWLEDGE ── */
  #hidden {
    background: var(--navy-deep);
    position: relative;
    overflow: hidden;
  }

  #hidden::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse 50% 60% at 20% 50%, rgba(201,168,76,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  #hidden .section-title {
    color: #fff;
  }

  #hidden .section-sub {
    color: rgba(255,255,255,0.5);
  }

  .knowledge-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    margin-top: 52px;
    background: rgba(255,255,255,0.06);
    border-radius: 12px;
    overflow: hidden;
  }

  .knowledge-card {
    background: rgba(13,31,60,0.8);
    padding: 32px 36px;
    position: relative;
  }

  .knowledge-card.full-width {
    grid-column: 1 / -1;
    background: rgba(201,168,76,0.08);
    border-top: 2px solid rgba(201,168,76,0.2);
  }

  .knowledge-icon {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 2px;
    color: var(--gold);
    margin-bottom: 14px;
    display: block;
    text-transform: uppercase;
  }

  .knowledge-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 10px;
  }

  .knowledge-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
  }

  .knowledge-badge {
    display: inline-block;
    background: rgba(201,168,76,0.15);
    color: var(--gold);
    font-size: 12px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 10px;
  }

  .factors-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
  }

  .factor-tag {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.7);
    font-size: 13px;
    padding: 6px 14px;
    border-radius: 100px;
  }

  .hidden-warning {
    margin-top: 36px;
    padding: 24px 32px;
    background: rgba(201,168,76,0.08);
    border-right: 3px solid var(--gold);
    border-radius: 0 8px 8px 0;
  }

  .hidden-warning p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: rgba(255,255,255,0.9);
    line-height: 1.5;
  }

  .hidden-warning strong {
    color: var(--gold);
    font-weight: 500;
  }

  /* ── REPORT ── */
  #report {
    background: var(--warm-gray);
  }

  .report-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 52px;
    align-items: start;
    margin-top: 52px;
  }

  .report-intro .section-title { margin-bottom: 20px; }

  .report-features {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 32px;
  }

  .report-feature {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .report-feature-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
    margin-top: 8px;
  }

  .report-feature-text {
    font-size: 15px;
    color: var(--text-dark);
    line-height: 1.6;
  }

  .report-feature-text strong {
    color: var(--navy);
    font-weight: 500;
    display: block;
    margin-bottom: 2px;
  }

  .report-card {
    background: var(--navy);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(13,31,60,0.2);
  }

  .report-card-header {
    background: var(--navy-deep);
    padding: 20px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .report-card-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
  }

  .report-badge {
    background: var(--green);
    color: #fff;
    font-size: 11px;
    font-weight: 500;
    padding: 4px 12px;
    border-radius: 100px;
  }

  .report-card-body {
    padding: 28px;
  }

  .report-unit-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: #fff;
    margin-bottom: 6px;
  }

  .report-unit-sub {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 28px;
  }

  .report-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: rgba(255,255,255,0.05);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .report-metric {
    background: rgba(13,31,60,0.6);
    padding: 16px 18px;
  }

  .report-metric-label {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    margin-bottom: 6px;
    display: block;
    letter-spacing: 0.5px;
  }

  .report-metric-value {
    font-size: 16px;
    font-weight: 500;
    color: #fff;
    display: block;
  }

  .report-metric-value.positive { color: var(--green); }
  .report-metric-value.warning  { color: #E8A020; }

  .report-bars {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }

  .report-bar-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .report-bar-label {
    font-size: 12px;
    color: rgba(255,255,255,0.45);
    width: 110px;
    flex-shrink: 0;
    text-align: right;
  }

  .report-bar-track {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.08);
    border-radius: 2px;
    overflow: hidden;
  }

  .report-bar-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--gold);
    transition: width 1s ease;
  }

  .report-bar-fill.green { background: var(--green); }
  .report-bar-fill.mid   { background: #E8A020; }

  .report-bar-score {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    width: 28px;
    text-align: left;
    flex-shrink: 0;
  }

  .report-verdict {
    background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 8px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .report-verdict-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(201,168,76,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--gold);
    font-size: 14px;
    font-weight: 700;
  }

  .report-verdict-text {
    font-size: 13px;
    color: rgba(255,255,255,0.65);
    line-height: 1.5;
  }

  .report-verdict-text strong {
    color: var(--gold);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .report-wrapper { grid-template-columns: 1fr; }
  }

  .report-id-row {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
  }
  .report-id-tag {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.4);
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 4px;
  }
  .report-id-tag span { color: var(--gold); font-weight: 500; margin-right: 4px; }
  .report-section-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 12px;
    margin-top: 4px;
  }
  .room-temps {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 20px;
  }
  .room-temp {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255,255,255,0.04);
    border-radius: 6px;
    padding: 8px 12px;
  }
  .room-name { font-size: 12px; color: rgba(255,255,255,0.5); }
  .room-badge { font-size: 10px; font-weight: 500; padding: 2px 8px; border-radius: 4px; }
  .room-badge.hot  { background: rgba(216,90,48,0.25); color: #F0997B; }
  .room-badge.warm { background: rgba(232,160,32,0.2); color: #E8A020; }
  .room-badge.cold { background: rgba(29,158,117,0.2); color: var(--green); }

  #solution {
    background: var(--warm-white);
  }

  .solution-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1px;
    margin-top: 52px;
    background: var(--divider);
    border: 1px solid var(--divider);
    border-radius: 12px;
    overflow: hidden;
  }

  .solution-card {
    background: #fff;
    padding: 36px 32px;
    text-align: center;
  }

  .solution-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 16px;
    display: block;
  }

  .solution-title {
    font-size: 15px;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 8px;
  }

  .solution-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ── HOW IT WORKS ── */
  #how {
    background: var(--navy);
  }

  #how .section-title { color: #fff; }
  #how .section-sub { color: rgba(255,255,255,0.5); }

  .steps {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 32px;
    margin-top: 52px;
  }

  .step {
    position: relative;
  }

  .step-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 72px;
    font-weight: 300;
    color: rgba(201,168,76,0.15);
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }

  .step-title {
    font-size: 16px;
    font-weight: 500;
    color: #fff;
    margin-bottom: 8px;
  }

  .step-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    line-height: 1.6;
  }

  .step-connector {
    position: absolute;
    top: 36px;
    left: -16px;
    width: 32px;
    height: 1px;
    background: linear-gradient(to left, rgba(201,168,76,0.3), transparent);
  }

  /* ── CTA ── */
  #cta {
    background: var(--warm-white);
    text-align: center;
    padding: 100px 5%;
  }

  .cta-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 300;
    color: var(--navy);
    line-height: 1.25;
    margin-bottom: 16px;
    letter-spacing: -0.3px;
  }

  .cta-sub {
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: 40px;
  }

  .cta-free-note {
    margin-top: 16px;
    font-size: 13px;
    color: var(--text-secondary);
  }

  .cta-free-note span {
    color: var(--green);
    font-weight: 500;
  }

  /* ── FOOTER ── */
  footer {
    background: var(--navy-deep);
    padding: 32px 5%;
    text-align: center;
  }

  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 400;
    margin-bottom: 8px;
  }
  .footer-logo span:first-child { color: var(--gold); }
  .footer-logo span:last-child { color: rgba(255,255,255,0.5); }

  .footer-copy {
    font-size: 12px;
    color: rgba(255,255,255,0.25);
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-inner > * {
    animation: fadeUp 0.7s ease both;
  }

  .hero-inner > *:nth-child(1) { animation-delay: 0.1s; }
  .hero-inner > *:nth-child(2) { animation-delay: 0.25s; }
  .hero-inner > *:nth-child(3) { animation-delay: 0.4s; }
  .hero-inner > *:nth-child(4) { animation-delay: 0.55s; }
  .hero-inner > *:nth-child(5) { animation-delay: 0.65s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .knowledge-grid { grid-template-columns: 1fr; }
    .solution-grid { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr; gap: 40px; }
    .step-connector { display: none; }
    .hero-trust { flex-direction: column; gap: 20px; }
    .trust-divider { width: 40px; height: 1px; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
